<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BUDHAI Lab — AI for Healthcare Research</title>

    <!-- Google Fonts: Clean & Professional -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet" />
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />

    <style>
        /* --- RESET & VARIABLES --- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-primary: #070c1a;
            --bg-secondary: #0d1428;
            --bg-card: rgba(255, 255, 255, 0.04);
            --border-glass: rgba(255, 255, 255, 0.06);
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
            --text-muted: #64748b;
            --accent-gold: #fbbf24;
            --accent-cyan: #38bdf8;
            --accent-purple: #818cf8;
            --shadow-glow: 0 8px 32px rgba(0, 0, 0, 0.4);
            --radius-lg: 24px;
            --radius-md: 16px;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-primary);
            color: var(--text-primary);
            line-height: 1.7;
            -webkit-font-smoothing: antialiased;
            overflow-x: hidden;
        }

        /* --- SCROLLBAR --- */
        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: var(--bg-primary);
        }
        ::-webkit-scrollbar-thumb {
            background: var(--accent-cyan);
            border-radius: 12px;
        }

        /* --- CANVAS BACKGROUND (Subtle Neural Network) --- */
        #particles-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            pointer-events: none;
            opacity: 0.5;
        }

        /* --- UTILITY --- */
        .container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 3rem;
            position: relative;
            z-index: 10;
        }

        .section-badge {
            display: inline-block;
            padding: 0.25rem 1rem;
            border-radius: 40px;
            background: rgba(56, 189, 248, 0.1);
            border: 1px solid rgba(56, 189, 248, 0.2);
            color: var(--accent-cyan);
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 0.5rem;
        }

        .section-title {
            font-size: 2.8rem;
            font-weight: 700;
            line-height: 1.2;
            letter-spacing: -0.02em;
            margin-bottom: 1rem;
        }
        .section-title .highlight {
            background: linear-gradient(135deg, var(--accent-gold), var(--accent-cyan));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .section-subtitle {
            color: var(--text-secondary);
            font-size: 1.15rem;
            max-width: 680px;
            margin: 0 auto 3rem auto;
        }

        .text-center {
            text-align: center;
        }

        /* --- GLASS CARD --- */
        .glass-card {
            background: var(--bg-card);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--border-glass);
            border-radius: var(--radius-lg);
            transition: all 0.4s ease;
        }
        .glass-card:hover {
            transform: translateY(-6px);
            border-color: rgba(56, 189, 248, 0.3);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
        }

        /* --- NAVIGATION --- */
        nav {
            padding: 1rem 0;
            background: rgba(7, 12, 26, 0.85);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            position: sticky;
            top: 0;
            z-index: 1000;
            transition: 0.3s;
        }

        nav .container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .logo svg {
            width: 40px;
            height: 40px;
            filter: drop-shadow(0 0 15px rgba(251, 191, 36, 0.2));
        }

        .logo-text {
            font-size: 1.6rem;
            font-weight: 700;
            letter-spacing: -0.5px;
            color: #fff;
        }
        .logo-text span {
            color: var(--accent-cyan);
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 2.5rem;
            list-style: none;
        }
        .nav-links a {
            text-decoration: none;
            color: var(--text-secondary);
            font-size: 0.9rem;
            font-weight: 500;
            transition: 0.3s;
            letter-spacing: 0.3px;
        }
        .nav-links a:hover {
            color: #fff;
        }

        .btn-donate-nav {
            background: var(--accent-gold);
            color: #070c1a !important;
            padding: 0.5rem 1.5rem;
            border-radius: 60px;
            font-weight: 700 !important;
            transition: 0.3s;
            box-shadow: 0 0 30px rgba(251, 191, 36, 0.15);
        }
        .btn-donate-nav:hover {
            background: #fcd34d !important;
            transform: scale(1.05);
            box-shadow: 0 0 50px rgba(251, 191, 36, 0.3);
        }

        /* --- HERO SECTION --- */
        .hero {
            padding: 6rem 0 4rem 0;
            min-height: 90vh;
            display: flex;
            align-items: center;
        }

        .hero-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 5rem;
            align-items: center;
        }

        .hero-content .acronym {
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--accent-gold);
            letter-spacing: 4px;
            margin-bottom: 0.5rem;
        }

        .hero-content h1 {
            font-size: 4.2rem;
            font-weight: 700;
            line-height: 1.1;
            letter-spacing: -0.03em;
            margin-bottom: 0.5rem;
        }
        .hero-content h1 .highlight {
            background: linear-gradient(135deg, var(--accent-gold), var(--accent-cyan));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero-content .full-meaning {
            font-size: 1.1rem;
            color: var(--text-secondary);
            margin-bottom: 1.5rem;
            border-left: 3px solid var(--accent-cyan);
            padding-left: 1.5rem;
        }
        .hero-content .full-meaning strong {
            color: #fff;
        }

        .hero-content .tagline {
            font-size: 1.5rem;
            font-weight: 500;
            color: #fff;
            margin-bottom: 1.5rem;
            font-style: italic;
        }
        .hero-content .tagline span {
            color: var(--accent-gold);
        }

        .hero-content p {
            color: var(--text-secondary);
            font-size: 1.1rem;
            max-width: 480px;
            margin-bottom: 2.5rem;
        }

        .hero-buttons {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .btn-primary {
            display: inline-block;
            padding: 0.9rem 2.8rem;
            border-radius: 60px;
            font-weight: 600;
            text-decoration: none;
            transition: 0.3s;
            border: none;
            cursor: pointer;
            font-size: 1rem;
        }
        .btn-primary.solid {
            background: #fff;
            color: #070c1a;
            box-shadow: 0 4px 20px rgba(255, 255, 255, 0.1);
        }
        .btn-primary.solid:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 40px rgba(255, 255, 255, 0.15);
        }

        .btn-primary.outline {
            background: transparent;
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        .btn-primary.outline:hover {
            border-color: #fff;
            background: rgba(255, 255, 255, 0.05);
        }

        .btn-donate-hero {
            background: var(--accent-gold);
            color: #070c1a !important;
            font-weight: 700;
            box-shadow: 0 4px 30px rgba(251, 191, 36, 0.3);
        }
        .btn-donate-hero:hover {
            background: #fcd34d;
            transform: translateY(-3px);
            box-shadow: 0 12px 50px rgba(251, 191, 36, 0.4);
        }

        /* Hero Logo */
        .hero-logo {
            display: flex;
            justify-content: center;
            align-items: center;
        }
        .hero-logo svg {
            width: 100%;
            max-width: 440px;
            height: auto;
            filter: drop-shadow(0 0 80px rgba(251, 191, 36, 0.1));
            animation: float 7s ease-in-out infinite;
        }
        @keyframes float {
            0%,
            100% {
                transform: translateY(0px);
            }
            50% {
                transform: translateY(-16px);
            }
        }

        /* --- STATS --- */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 2rem;
            margin-top: 4rem;
            padding: 2.5rem 0;
            border-top: 1px solid rgba(255, 255, 255, 0.04);
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        }
        .stat-item {
            text-align: center;
        }
        .stat-item .number {
            font-size: 3rem;
            font-weight: 700;
            color: #fff;
            display: block;
            line-height: 1.2;
        }
        .stat-item .number .plus {
            color: var(--accent-cyan);
        }
        .stat-item .label {
            color: var(--text-muted);
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* --- SECTIONS --- */
        section {
            padding: 6rem 0;
        }

        #research {
            background: var(--bg-secondary);
        }

        .card-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
        }

        .research-card {
            padding: 2.5rem 2rem;
            text-align: left;
            position: relative;
            overflow: hidden;
        }
        .research-card .icon {
            font-size: 2.5rem;
            color: var(--accent-gold);
            margin-bottom: 1.2rem;
            display: block;
        }
        .research-card h3 {
            font-size: 1.3rem;
            font-weight: 600;
            margin-bottom: 0.6rem;
        }
        .research-card p {
            color: var(--text-secondary);
            font-size: 0.95rem;
            margin-bottom: 1.5rem;
        }
        .research-card .tag {
            display: inline-block;
            padding: 0.2rem 1rem;
            border-radius: 40px;
            background: rgba(56, 189, 248, 0.08);
            border: 1px solid rgba(56, 189, 248, 0.1);
            color: var(--accent-cyan);
            font-size: 0.75rem;
            font-weight: 600;
        }

        /* --- PROCESS --- */
        .process-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2.5rem;
            margin-top: 2rem;
        }
        .process-step {
            text-align: center;
            padding: 1.5rem;
        }
        .process-step .step-num {
            font-size: 3.5rem;
            font-weight: 700;
            color: rgba(56, 189, 248, 0.1);
            line-height: 1;
            margin-bottom: 0.5rem;
            font-feature-settings: "tnum";
        }
        .process-step h4 {
            font-size: 1.3rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
        }
        .process-step p {
            color: var(--text-secondary);
            font-size: 0.95rem;
        }

        /* --- DONATE SECTION (Premium) --- */
        #donate {
            background: radial-gradient(ellipse at center, rgba(251, 191, 36, 0.04), transparent 70%);
            padding: 6rem 0;
        }

        .donate-wrapper {
            max-width: 900px;
            margin: 0 auto;
            background: var(--bg-card);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--border-glass);
            border-radius: var(--radius-lg);
            padding: 3.5rem 4rem;
            text-align: center;
        }

        .donate-wrapper h2 {
            font-size: 2.4rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }
        .donate-wrapper .sub {
            color: var(--text-secondary);
            margin-bottom: 2.5rem;
            font-size: 1.05rem;
        }

        .donate-tiers {
            display: flex;
            justify-content: center;
            gap: 1rem;
            flex-wrap: wrap;
            margin-bottom: 2rem;
        }
        .tier-btn {
            padding: 0.7rem 2rem;
            border-radius: 60px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            background: transparent;
            color: #fff;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
            font-size: 1rem;
            min-width: 80px;
        }
        .tier-btn:hover,
        .tier-btn.active {
            border-color: var(--accent-gold);
            background: rgba(251, 191, 36, 0.1);
            color: var(--accent-gold);
        }
        .tier-btn.active {
            background: var(--accent-gold);
            color: #070c1a;
            border-color: var(--accent-gold);
        }

        .donate-actions {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-donate-lg {
            background: var(--accent-gold);
            color: #070c1a;
            padding: 1rem 4rem;
            border-radius: 60px;
            font-weight: 700;
            font-size: 1.1rem;
            border: none;
            cursor: pointer;
            transition: 0.3s;
            box-shadow: 0 4px 30px rgba(251, 191, 36, 0.2);
            text-decoration: none;
            display: inline-block;
        }
        .btn-donate-lg:hover {
            transform: scale(1.04);
            box-shadow: 0 8px 50px rgba(251, 191, 36, 0.4);
            background: #fcd34d;
        }

        .donate-note {
            margin-top: 1.5rem;
            font-size: 0.85rem;
            color: var(--text-muted);
        }
        .donate-note i {
            color: var(--accent-gold);
        }

        /* --- FOOTER --- */
        footer {
            padding: 3rem 0;
            border-top: 1px solid rgba(255, 255, 255, 0.04);
            text-align: center;
            color: var(--text-muted);
            font-size: 0.9rem;
        }
        footer .brand {
            color: #fff;
            font-weight: 600;
        }
        footer .brand span {
            color: var(--accent-cyan);
        }
        footer .heart {
            color: #ef4444;
        }

        /* --- RESPONSIVE --- */
        @media (max-width: 1024px) {
            .hero-grid {
                grid-template-columns: 1fr;
                text-align: center;
                gap: 3rem;
            }
            .hero-content p {
                margin: 0 auto 2rem auto;
            }
            .hero-content .full-meaning {
                border-left: none;
                padding-left: 0;
                text-align: center;
            }
            .hero-buttons {
                justify-content: center;
            }
            .card-grid,
            .process-grid {
                grid-template-columns: 1fr 1fr;
            }
            .stats-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        @media (max-width: 768px) {
            .container {
                padding: 0 1.5rem;
            }
            nav .container {
                flex-direction: column;
                gap: 1rem;
            }
            .nav-links {
                gap: 1.5rem;
                flex-wrap: wrap;
                justify-content: center;
            }
            .hero-content h1 {
                font-size: 3rem;
            }
            .section-title {
                font-size: 2.2rem;
            }
            .card-grid,
            .process-grid {
                grid-template-columns: 1fr;
            }
            .donate-wrapper {
                padding: 2rem 1.5rem;
            }
            .stats-grid {
                grid-template-columns: 1fr 1fr;
                gap: 1.5rem;
            }
            .stat-item .number {
                font-size: 2.2rem;
            }
            .hero-logo svg {
                max-width: 280px;
            }
        }

        @media (max-width: 480px) {
            .hero-content h1 {
                font-size: 2.4rem;
            }
            .btn-primary {
                padding: 0.7rem 1.8rem;
                font-size: 0.9rem;
            }
            .donate-tiers {
                gap: 0.5rem;
            }
            .tier-btn {
                padding: 0.5rem 1.2rem;
                font-size: 0.9rem;
            }
        }
    </style>
</head>
<body>

    <!-- Particle Background -->
    <canvas id="particles-canvas"></canvas>

    <!-- Navigation -->
    <nav>
        <div class="container">
            <a href="#" class="logo">
                <!-- Minimalist Buddha + AI SVG -->
                <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="50" cy="48" r="28" stroke="#FBBF24" stroke-width="2.5" stroke-linecap="round"/>
                    <path d="M50 20 C50 14, 55 8, 50 2 C45 8, 50 14, 50 20" fill="#FBBF24" fill-opacity="0.6" />
                    <path d="M35 48 L45 48 L50 42 L55 48 L65 48" stroke="#38BDF8" stroke-width="2" stroke-linecap="round"/>
                    <circle cx="50" cy="42" r="3" fill="#38BDF8" fill-opacity="0.9" />
                    <path d="M40 46 Q45 42, 50 46" stroke="#FBBF24" stroke-width="2" stroke-linecap="round"/>
                    <path d="M50 46 Q55 42, 60 46" stroke="#FBBF24" stroke-width="2" stroke-linecap="round"/>
                    <circle cx="22" cy="48" r="3" fill="#38BDF8" fill-opacity="0.4" />
                    <circle cx="78" cy="48" r="3" fill="#38BDF8" fill-opacity="0.4" />
                    <line x1="25" y1="48" x2="35" y2="48" stroke="#38BDF8" stroke-width="1.5" stroke-dasharray="2 2" />
                    <line x1="65" y1="48" x2="75" y2="48" stroke="#38BDF8" stroke-width="1.5" stroke-dasharray="2 2" />
                </svg>
                <div class="logo-text">BUDHAI<span>Lab</span></div>
            </a>
            <ul class="nav-links">
                <li><a href="#research">Research</a></li>
                <li><a href="#process">Process</a></li>
                <li><a href="#donate">Support</a></li>
                <li><a href="#join" class="btn-donate-nav"><i class="fas fa-hand-holding-heart"></i> Donate</a></li>
            </ul>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <div class="container">
            <div class="hero-grid">
                <div class="hero-content">
                    <div class="acronym">> BUDHAI</div>
                    <h1>
                        AI for <br /><span class="highlight">Healthcare</span>
                    </h1>
                    <div class="full-meaning">
                        <strong>B</strong>old · <strong>U</strong>nified · <strong>D</strong>ata · <strong>H</strong>ealthcare · <strong>AI</strong>
                    </div>
                    <div class="tagline">
                        “<span>Exchanging Ideas</span>. <span>Evolving Intelligence</span>. Empowering Health.”
                    </div>
                    <p>
                        A non-profit, peer-driven research collective where wisdom meets artificial intelligence.
                        No supervisors. Just collaborators transforming medicine through open science.
                    </p>
                    <div class="hero-buttons">
                        <a href="#join" class="btn-primary solid">Join the Lab</a>
                        <a href="#donate" class="btn-primary btn-donate-hero"><i class="fas fa-heart"></i> Support Research</a>
                    </div>
                </div>
                <div class="hero-logo">
                    <!-- Large Hero SVG -->
                    <svg viewBox="0 0 300 300" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="150" cy="140" r="90" stroke="#FBBF24" stroke-width="3" stroke-linecap="round" opacity="0.7"/>
                        <path d="M150 40 C150 20, 165 10, 150 0 C135 10, 150 20, 150 40" fill="#FBBF24" fill-opacity="0.7" />
                        <path d="M80 140 L120 140 L135 120 L165 120 L180 140 L220 140" stroke="#38BDF8" stroke-width="3" stroke-linecap="round"/>
                        <circle cx="150" cy="120" r="8" fill="#38BDF8" fill-opacity="0.9" />
                        <path d="M110 130 Q130 120, 150 130" stroke="#FBBF24" stroke-width="3" stroke-linecap="round"/>
                        <path d="M150 130 Q170 120, 190 130" stroke="#FBBF24" stroke-width="3" stroke-linecap="round"/>
                        <circle cx="50" cy="140" r="6" fill="#38BDF8" fill-opacity="0.3" />
                        <circle cx="250" cy="140" r="6" fill="#38BDF8" fill-opacity="0.3" />
                        <circle cx="80" cy="80" r="5" fill="#818CF8" fill-opacity="0.4" />
                        <circle cx="220" cy="80" r="5" fill="#818CF8" fill-opacity="0.4" />
                        <!-- Floating particles -->
                        <circle cx="40" cy="40" r="3" fill="#38BDF8" opacity="0.6">
                            <animate attributeName="opacity" values="0.2;1;0.2" dur="4s" repeatCount="indefinite" />
                        </circle>
                        <circle cx="260" cy="50" r="3" fill="#FBBF24" opacity="0.6">
                            <animate attributeName="opacity" values="0.2;1;0.2" dur="5s" repeatCount="indefinite" />
                        </circle>
                    </svg>
                </div>
            </div>

            <!-- Stats -->
            <div class="stats-grid">
                <div class="stat-item">
                    <span class="number" data-target="28">0</span>
                    <span class="label">Active Researchers</span>
                </div>
                <div class="stat-item">
                    <span class="number" data-target="15">0</span>
                    <span class="label">Active Projects</span>
                </div>
                <div class="stat-item">
                    <span class="number" data-target="12">0</span>
                    <span class="label">Datasets Explored</span>
                </div>
                <div class="stat-item">
                    <span class="number" data-target="156">0</span>
                    <span class="label">Ideas Exchanged</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Research Pillars -->
    <section id="research">
        <div class="container">
            <div class="text-center">
                <span class="section-badge">Research Pillars</span>
                <h2 class="section-title">Where <span class="highlight">AI</span> Meets Life Sciences</h2>
                <p class="section-subtitle">Our collaborative efforts focus on three core domains to redefine healthcare through intelligence.</p>
            </div>

            <div class="card-grid">
                <div class="research-card glass-card">
                    <span class="icon"><i class="fas fa-brain"></i></span>
                    <h3>Deep Learning & Imaging</h3>
                    <p>Developing CNN, Transformer, and GAN architectures for medical image analysis, pathology, and radiology.</p>
                    <span class="tag"><i class="fas fa-code"></i> PyTorch · TensorFlow</span>
                </div>
